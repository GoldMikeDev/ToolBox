<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<AssemblyName>ToolBox</AssemblyName>
		<Authors>GoldMike</Authors>
		<Description>Container for running my other CLI tools.</Description>
		<ImplicitUsings>enable</ImplicitUsings>
		<IsPackable>true</IsPackable>
		<LangVersion>14</LangVersion>
		<NoWarn>$(NoWarn);NU5111</NoWarn>
		<Nullable>enable</Nullable>
		<OutputType>Exe</OutputType>
		<PackAsTool>true</PackAsTool>
		<PackageId>ToolBox</PackageId>
		<PackageOutputPath>./bin/Release/nupkg</PackageOutputPath>
		<TargetFramework>net10.0</TargetFramework>
		<ToolCommandName>ToolBox</ToolCommandName>
		<Version>1.6.5</Version>
	</PropertyGroup>
	<ItemGroup>
		<None Include="AddonModules\Updater\UpdateScript.ps1">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
		</None>
	</ItemGroup>
</Project>